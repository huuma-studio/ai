{
  "nodeModulesDir": "auto",
  "name": "@huuma/ai",
  "version": "0.0.6",
  "description": "Composable AI primitives for Deno and TypeScript: model adapters, agents, workflows, and tool factories.",
  "license": "MIT",
  "exports": {
    ".": "./src/mod.ts",
    "./model": "./src/model/mod.ts",
    "./workflow": "./src/workflow/mod.ts",
    "./models": "./models/mod.ts",
    "./models/google": "./models/google/mod.ts",
    "./models/ollama": "./models/ollama/mod.ts",
    "./models/openai": "./models/openai/mod.ts",
    "./agent": "./src/agent/mod.ts",
    "./tools": "./src/tools/mod.ts"
  },
  "tasks": {
    "check": "deno check",
    "test": "deno test --allow-read --allow-write --allow-env --allow-run --allow-net",
    "lint": "deno lint",
    "publish:dry-run": "deno publish --dry-run --allow-dirty"
  },
  "publish": {
    "exclude": [
      ".github/",
      "main.ts",
      "tasks.json",
      "progress.txt",
      "**/*_test.ts",
      "**/*.test.ts"
    ]
  },
  "imports": {
    "@deno/sandbox": "jsr:@deno/sandbox@^0.13.2",
    "@google/genai": "npm:@google/genai@^2.8.0",
    "@anthropic-ai/sdk": "npm:@anthropic-ai/sdk@^0.100.1",
    "@std/fs": "jsr:@std/fs@^1.0.24",
    "ollama": "npm:ollama@^0.6.3",
    "@huuma/validate": "jsr:@huuma/validate@^0.1.5",
    "@std/front-matter": "jsr:@std/front-matter@^1.0.9",
    "@/": "./src/",
    "@std/path": "jsr:@std/path@^1.1.5",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "node-html-markdown": "npm:node-html-markdown@^2.0.0",
    "openai": "npm:openai@^6.42.0"
  }
}
